node_modules/

# Secrets / runtime config (generated by bootstrap.sh — never commit)
.env
config/.env
*.env
!*.env.example

# Data / runtime output
data/
*.log
tmp/

# Local session / tooling dirs (not part of the project)
.remember/
.claude/

# Large binaries / archives (not source)
*.zip
*.pdf

# OS cruft
.DS_Store
__MACOSX/
Thumbs.db
