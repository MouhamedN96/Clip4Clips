# ============================================
# CLIPFORGE VPS CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=3000
DOMAIN=https://your-domain.com
API_SECRET=generate-a-secure-random-string-here

# ============================================
# BRANDING / WHITE-LABEL
# ============================================
# One deploy = one brand. Change these to rebrand an instance for a reseller.
# bootstrap.sh will prompt for BRAND_NAME/BRAND_DOMAIN and fill them here.
BRAND_NAME=ClipForge
BRAND_DOMAIN=https://your-domain.com
BRAND_SUPPORT_EMAIL=support@your-domain.com
BRAND_PRIMARY_COLOR=#5b8def

# ============================================
# WHOP CONFIGURATION
# ============================================
# Get these from https://whop.com/dashboard/developers
WHOP_API_KEY=whp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHOP_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHOP_MERCHANT_ID=wh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHOP_API_URL=https://api.whop.com

# Whop Affiliate Settings
WHOP_DEFAULT_COMMISSION=30
WHOP_REFERRAL_COMMISSION=25
WHOP_COOKIE_DURATION_DAYS=60

# ============================================
# AI SERVICES
# ============================================
# DeepSeek - https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# API model id (not "v4"). "deepseek-chat" is renamed to "deepseek-v4-flash" after 2026-07-24.
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096

# Claude (Anthropic) - https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=4096

# OpenAI (Backup)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# DATABASE
# ============================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clipforge
POSTGRES_USER=clipforge
POSTGRES_PASSWORD=change-this-secure-password

# ============================================
# REDIS
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-secure-password
REDIS_DB=0

# ============================================
# HERMES DEVICE FARM
# ============================================
# WebSocket relay URL for Hermes farm
HERMES_RELAY_URL=wss://your-hermes-relay.com:8766
HERMES_API_KEY=hermes_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HERMES_PHONE_COUNT=48
HERMES_CONNECTION_TIMEOUT=30000

# Phone allocation tiers
HERMES_TIER1_COUNT=12  # TikTok US
HERMES_TIER2_COUNT=12  # TikTok UK/EU
HERMES_TIER3_COUNT=12  # Instagram + Twitter
HERMES_TIER4_COUNT=12  # YouTube Shorts

# ============================================
# INTELLIGENCE / LEAD DISCOVERY
# ============================================
# Not done in-app. The operator agent handles lead discovery + trend/competitor
# research via connected MCP servers. Put these keys in the AGENT's MCP config
# (config/mcp.example.json), not here:
#   ScrapeCreators (creator/lead data), Apify (24k actors incl. Reddit/social),
#   Exa / Perplexity / Firecrawl (research). ClipForge reads none of them.

# ============================================
# VIDEO PROCESSING
# ============================================
# yt-dlp settings
YTDLP_FORMAT=bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best
FFMPEG_PATH=/usr/bin/ffmpeg

# Where produced clips/sources are written (worker + pipeline + higgsfield)
CLIP_DATA_DIR=/app/data

# ============================================
# ASR / CAPTIONS (highlight scoring + burned subtitles)
# ============================================
# Leave all unset to run the free naive-window + no-caption path on the €20 box.
# fal.ai Whisper (preferred): https://fal.run/fal-ai/whisper
FAL_KEY=
FAL_BASE_URL=https://fal.run
FAL_WHISPER_PATH=/fal-ai/whisper
# OR a generic OpenAI-compatible transcription endpoint (full URL):
ASR_ENDPOINT=
ASR_API_KEY=
ASR_MODEL=whisper-1
ASR_LANGUAGE=

# Optional Claude overrides used by src/integration/llm.js
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_API_VERSION=2023-06-01

# ============================================
# HIGGSFIELD (generative SMB spec-ad path)
# ============================================
# Auth is "Key {KEY_ID}:{KEY_SECRET}". Put the pair in HIGGSFIELD_API_KEY, or
# split across the two vars. Unset = spec-ad path is skipped, not failed.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_API_BASE=https://platform.higgsfield.ai
HIGGSFIELD_MODEL=kling/v3/text-to-video          # cheap default (~6 credits); VERIFY slug in console
HIGGSFIELD_PREMIUM_MODEL=openai/sora-2/text-to-video  # used only when premium:true; VERIFY slug
HIGGSFIELD_RESOLUTION=720p
HIGGSFIELD_POLL_INTERVAL_MS=5000
HIGGSFIELD_POLL_TIMEOUT_MS=600000

# ============================================
# STOCK FOOTAGE (free SMB reel path, $0 COGS)
# ============================================
# Either key enables /api/reels/generate. Pexels is tried first, Pixabay is fallback.
# Pexels: https://www.pexels.com/api/   Pixabay: https://pixabay.com/api/docs/
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ============================================
# PLATFORM CREDENTIALS
# ============================================
# TikTok
TIKTOK_SESSION_COOKIES=sessionid=xxx;tt_webid_v2=xxx

# YouTube
YOUTUBE_COOKIES=LOGIN_INFO=xxx;SID=xxx

# Twitter/X
TWITTER_COOKIES=auth_token=xxx;ct0=xxx

# Instagram
INSTAGRAM_COOKIES=sessionid=xxx;csrftoken=xxx

# ============================================
# PAYMENT SETTINGS
# ============================================
# Stripe (alternative payment processor)
STRIPE_SECRET_KEY=sk_live_<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-secret>

# LemonSqueezy (alternative)
LEMONSQUEEZY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEMONSQUEEZY_STORE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LEMONSQUEEZY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# NOTIFICATIONS
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
SLACK_CHANNEL=#clipforge-alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM=alerts@your-domain.com

# ============================================
# RATE LIMITS & SAFETY
# ============================================
MAX_DMS_PER_ACCOUNT_PER_DAY=5
MIN_DELAY_BETWEEN_DMS_SECONDS=300
MAX_CONCURRENT_HERMES_CONNECTIONS=10
OUTREACH_COOLDOWN_DAYS=7

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=/app/logs

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_AUTO_POSTING=true
ENABLE_REVENUE_SHARE=true
ENABLE_AFFILIATE_TRACKING=true
ENABLE_ANALYTICS=true
ENABLE_VIRAL_BONUSES=true

# Viral bonus thresholds (USD)
VIRAL_BONUS_1M=100
VIRAL_BONUS_10M=500
VIRAL_BONUS_50M=2500

# ============================================
# SERVICE URLS
# ============================================
WHOP_WEBHOOK_URL=https://your-domain.com/api/webhooks/whop
STRIPE_WEBHOOK_URL=https://your-domain.com/api/webhooks/stripe
LEMONSQUEEZY_WEBHOOK_URL=https://your-domain.com/api/webhooks/lemonsqueezy
